package main

main : proc() = {
	var i := 0

outerLoop:
	for {
	innerLoop:
		for {
			i = i + 1

			if (i < 5) {
				@print("continue")
				continue innerLoop
			}

			@print("break")
			break outerLoop
		}
	}

	for 10 {
		@print("loop")
	}

	count := 6
	for count {
		@print("count")
	}

	str := "hello"
	for str {
		@print(str)
	}
}
